<?xml version="1.0"?>
<ruleset name="BitApps/wpp">
  <description>Coding standard used for wp plugin dev.</description>
  <file>./backend</file>
  <exclude-pattern>*/tests/*</exclude-pattern>
  <exclude-pattern>tests.*</exclude-pattern>
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern type="relative">^/frontend/*</exclude-pattern>

  <arg value="sp" />
  <!-- Show sniff and progress -->
  <arg name="basepath" value="./" /><!-- Strip the file paths down to the relevant bit -->
  <arg name="colors" />
  <arg name="extensions" value="php" />
  <arg name="parallel" value="32" />

  <!-- Rules: Check PHP version compatibility -->
  <!-- https://github.com/PHPCompatibility/PHPCompatibilityWP -->
  <rule ref="PHPCompatibilityWP" />
  <config name="testVersion" value="7.4-" />

  <config name="minimum_supported_wp_version" value="5.8" />
  <rule ref="WordPress.WP.I18n">
    <properties>
      <property name="text_domain" type="array" value="wp-starter-kit" />
    </properties>
  </rule>

  <rule ref="PSR12">
    <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>
  </rule>

  <rule ref="PSR1.Classes.ClassDeclaration.MissingNamespace">
    <exclude-pattern>*/migrations/*</exclude-pattern>
  </rule>

  <rule ref="VariableAnalysis">
    <exclude name="VariableAnalysis.CodeAnalysis.VariableAnalysis.UndefinedVariable"/>
  </rule>

  <!-- for strict type -->
  <!-- <rule ref="SlevomatCodingStandard.TypeHints.DeclareStrictTypes" /> -->

  <!-- Base Standards -->
  <rule ref="Internal.Tokenizer.Exception">
    <type>error</type>
  </rule>
  <rule ref="PEAR">
    <exclude name="PEAR.NamingConventions.ValidFunctionName" />
    <exclude name="PEAR.NamingConventions.ValidVariableName" />
    <exclude name="PEAR.Commenting.ClassComment" />
    <exclude name="PEAR.Commenting.FileComment" />
    <exclude name="PEAR.WhiteSpace.ScopeIndent" />
    <exclude name="PEAR.Commenting.FunctionComment" />
    <exclude name="PEAR.Commenting.InlineComment" />
    <exclude name="PEAR.ControlStructures.MultiLineCondition" />
    <!-- <exclude name="PEAR.Commenting.FileComment.Missing" /> -->
    <!-- <exclude name="PEAR.Commenting.FunctionComment.MissingParamComment" /> -->
    <!-- <exclude name="PEAR.Commenting.FileComment.MissingCategoryTag" />
        <exclude name="PEAR.Commenting.FileComment.MissingPackageTag" />
        <exclude name="PEAR.Commenting.FileComment.MissingLinkTag" />
        <exclude name="PEAR.Commenting.FileComment.MissingVersion" /> -->
  </rule>

  <!-- General PHP Rules -->
  <rule ref="Generic.PHP.DeprecatedFunctions" />
  <rule ref="Generic.PHP.LowerCaseKeyword" />
  <rule ref="Generic.PHP.ForbiddenFunctions">
    <properties>
      <property name="forbiddenFunctions" type="array">
        <element key="sizeof" value="count" />
        <element key="delete" value="unset" />
        <element key="print" value="error_log" />
        <element key="print_r" value="error_log" />
        <element key="var_dump" value="error_log" />
        <element key="echo" value="error_log" />
        <element key="eval" value="null" />
        <element key="create_function" value="null" />
      </property>
    </properties>
  </rule>
  <rule ref="PSR12.Files.OpenTag" />
  <rule ref="Zend.Files.ClosingTag" />
  <rule ref="PSR2.Files.EndFileNewline" />
  <rule ref="Generic.Files.LineLength">
    <properties>
      <property name="lineLimit" value="200" />
      <property name="absoluteLineLimit" value="200" />
    </properties>
  </rule>

  <!-- Whitespace and Formatting Rules -->
  <rule ref="Generic.WhiteSpace.IncrementDecrementSpacing" />
  <rule ref="Generic.Formatting.DisallowMultipleStatements" />
  <rule ref="Generic.Formatting.SpaceAfterCast" />
  <rule ref="Generic.Formatting.MultipleStatementAlignment">
    <!-- <exclude name="Generic.Formatting.MultipleStatementAlignment.NotSame" /> -->
    <!-- <exclude name="Generic.Formatting.MultipleStatementAlignment.Incorrect" /> -->
    <exclude name="Generic.Formatting.MultipleStatementAlignment.NotSameWarning" />
  </rule>
  <rule ref="Squiz.WhiteSpace.ControlStructureSpacing">
    <exclude name="Squiz.WhiteSpace.ControlStructureSpacing.SpacingAfterOpenBrace" />
  </rule>
  <rule ref="Squiz.WhiteSpace.MemberVarSpacing">
    <exclude name="Squiz.WhiteSpace.MemberVarSpacing.FirstIncorrect" />
  </rule>
  <rule ref="Squiz.WhiteSpace.OperatorSpacing">
    <exclude name="Squiz.WhiteSpace.OperatorSpacing.SpacingBefore" />
  </rule>
  <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace" />
  <rule ref="Squiz.Formatting.OperatorBracket">
    <exclude name="Squiz.Formatting.OperatorBracket.MissingBrackets" />
  </rule>
  <rule ref="Generic.ControlStructures.DisallowYodaConditions.Found">
    <exclude name="Generic.ControlStructures.DisallowYodaConditions.Found" />
  </rule>

  <!-- Naming Conventions -->
  <rule ref="Generic.NamingConventions.ConstructorName" />
  <rule ref="Squiz.NamingConventions.ValidVariableName" />
  <rule ref="Squiz.NamingConventions.ValidVariableName.MemberNotCamelCaps">
    <severity>0</severity>
  </rule>
  <rule ref="Squiz.NamingConventions.ValidVariableName.NotCamelCaps">
    <exclude name="Squiz.NamingConventions.ValidVariableName.NotCamelCaps" />
  </rule>
  <rule ref="Squiz.NamingConventions.ValidVariableName.PrivateNoUnderscore">
    <exclude name="Squiz.NamingConventions.ValidVariableName.PrivateNoUnderscore" />
  </rule>

  <exclude name="Squiz.WhiteSpace.VariableSpacing" />
  <exclude name="Squiz.WhiteSpace.SemicolonSpacing" />
  <exclude name="Generic.WhiteSpace.ScopeIndent" />
  <exclude name="Generic.WhiteSpace.DisallowTabIndent" />
  <exclude name="PEAR.WhiteSpace.ObjectOperatorIndent" />
  <!-- <exclude name="Squiz.WhiteSpace.ControlStructureSpacing" /> -->


  <!-- Disable comment indentation rules to prevent conflicts with PHP-CS-Fixer -->
  <rule ref="PEAR.Commenting.ClassComment.MissingShort">
    <severity>0</severity>
  </rule>
  <rule ref="Squiz.Commenting.FunctionComment.WrongStyle">
    <severity>0</severity>
  </rule>
  <rule ref="Squiz.Commenting.DocCommentAlignment">
    <severity>0</severity>
  </rule>

  <!-- Control Structures -->
  <rule ref="Generic.ControlStructures.DisallowYodaConditions" />
  <rule ref="Generic.ControlStructures.InlineControlStructure">
    <properties>
      <property name="error" value="true" />
    </properties>
  </rule>
  <rule ref="Squiz.ControlStructures.ControlSignature" />

  <!-- Add rules for new lines before return and break statements -->
  <rule ref="PSR2.ControlStructures.ElseIfDeclaration" />
  <rule ref="Squiz.WhiteSpace.ControlStructureSpacing">
    <!-- Using default settings since custom spacing properties are invalid -->
  </rule>
  <!-- Add specific rules for blank lines before statements -->
  <rule ref="Squiz.ControlStructures.LowercaseDeclaration" />
  <rule ref="Squiz.WhiteSpace.ScopeClosingBrace" />



  <!-- Custom rule for new line before return/break statements -->
  <!-- <rule ref="Generic.Formatting.SpaceAfterNot" /> -->
  <!-- <rule ref="Squiz.WhiteSpace.LogicalOperatorSpacing" /> -->

  <!-- Arrays -->
  <rule ref="Generic.Arrays.DisallowLongArraySyntax" />
  <rule ref="Generic.Arrays.ArrayIndent" />
  <rule ref="Squiz.Arrays.ArrayBracketSpacing" />
  <!-- Removing the conflicting Squiz.Arrays.ArrayDeclaration rule -->
  <!-- <rule ref="Squiz.Arrays.ArrayDeclaration" /> -->
  <!-- Instead, only include specific parts that don't conflict with PHP-CS-Fixer -->
  <rule ref="Squiz.Arrays.ArrayDeclaration.NoCommaAfterLast" />
  <rule ref="Squiz.Arrays.ArrayDeclaration.MultiLineNotAllowed">
    <severity>0</severity>
  </rule>
  <!-- Remove all the previously excluded or zeroed ArrayDeclaration rules -->

  <!-- Add a custom rule for indentation consistency -->
  <rule ref="Generic.WhiteSpace.ScopeIndent">
    <properties>
      <property name="indent" value="4" />
      <property name="tabIndent" value="false" />
    </properties>
  </rule>

  <!-- Blank Line Rules - Enable rules for blank lines before statements -->
  <rule ref="Squiz.WhiteSpace.FunctionSpacing">
    <properties>
      <property name="spacing" value="1" />
      <property name="spacingBeforeFirst" value="0" />
      <property name="spacingAfterLast" value="0" />
    </properties>
  </rule>
  <rule ref="Squiz.WhiteSpace.FunctionOpeningBraceSpace" />

  <!-- Add control structure spacing rule with correct properties -->
  <rule ref="Squiz.WhiteSpace.ControlStructureSpacing">
    <!-- Using default settings since custom spacing properties are invalid -->
  </rule>

  <rule ref="Squiz.ControlStructures.ControlSignature.SpaceAfterKeyword" />

  <rule ref="Squiz.WhiteSpace.FunctionSpacing">
    <properties>
      <property name="spacing" value="1" />
      <property name="spacingBeforeFirst" value="0" />
      <property name="spacingAfterLast" value="0" />
    </properties>
  </rule>
  <!-- Functions and Methods -->
  <rule ref="Generic.Strings.UnnecessaryStringConcat" />
  <rule ref="Squiz.Functions.FunctionDeclarationArgumentSpacing">
    <exclude name="Squiz.Functions.FunctionDeclarationArgumentSpacing.SpaceBeforeEquals" />
    <exclude name="Squiz.Functions.FunctionDeclarationArgumentSpacing.SpaceAfterEquals" />
  </rule>
  <rule ref="Squiz.Scope.MethodScope" />
  <rule ref="PSR2.Classes.PropertyDeclaration">
    <exclude name="PSR2.Classes.PropertyDeclaration.Underscore" />
  </rule>
  <rule ref="PSR2.Methods.MethodDeclaration" />
  <rule ref="PEAR.Functions.FunctionCallSignature">
    <properties>
      <property name="allowMultipleArguments" value="false" />
    </properties>
  </rule>
</ruleset>
