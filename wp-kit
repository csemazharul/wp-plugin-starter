#!/usr/bin/env php
<?php

define('KIT_ROOT', __DIR__);

// ── CLI helpers ───────────────────────────────────────────────────────────────

function cli_ask(string $prompt, string $default = ''): string
{
    $hint = $default !== '' ? " [{$default}]" : '';
    echo cli_blue($prompt . $hint . ': ');
    $line = trim(fgets(STDIN));
    return $line !== '' ? $line : $default;
}

function cli_confirm(string $prompt): bool
{
    echo cli_blue($prompt . ' [y/N]: ');
    return strtolower(trim(fgets(STDIN))) === 'y';
}

function cli_cyan(string $s): string   { return "\033[36m{$s}\033[0m"; }
function cli_green(string $s): string  { return "\033[32m{$s}\033[0m"; }
function cli_yellow(string $s): string { return "\033[33m{$s}\033[0m"; }
function cli_red(string $s): string    { return "\033[31m{$s}\033[0m"; }
function cli_blue(string $s): string   { return "\033[34m{$s}\033[0m"; }
function cli_bold(string $s): string   { return "\033[1m{$s}\033[0m"; }

function cli_ok(string $s): void   { echo cli_green("  ✓ ") . $s . "\n"; }
function cli_err(string $s): void  { echo cli_red("  ✗ ") . $s . "\n"; }

// ── Commands ──────────────────────────────────────────────────────────────────

function cmd_plugin_init(): void
{
    echo cli_bold(cli_cyan("\nWP Starter Kit — Plugin Initializer\n\n"));

    $info = collect_plugin_info();

    echo "\n" . cli_bold(cli_green("Congratulations! Your plugin is ready to develop.\n"));
    render_summary_table($info);

    echo "\n";
    if (!cli_confirm('Proceed and replace all placeholders?')) {
        echo cli_yellow("Cancelled.\n");
        exit(0);
    }

    echo "\n";
    // Order matters: apply_replacements reads CURRENT values from Config.php as
    // "from" keys, so it must run BEFORE Config.php is rewritten with new values.
    process_all_files($info);
    update_config_constants($info);
    create_main_file($info);
    run_composer_install();

    echo "\n";
    cli_ok('Run `php wp-kit --help` to see make:* commands.');
}

function cmd_plugin_info(): void
{
    $config = KIT_ROOT . '/backend/app/Config.php';
    $src = file_exists($config) ? file_get_contents($config) : '';

    preg_match("/const SLUG\s*=\s*'([^']+)'/", $src, $slug);
    preg_match("/const TITLE\s*=\s*'([^']+)'/", $src, $title);
    preg_match('/^namespace\s+([\w\\\\]+);/m', $src, $ns);

    echo cli_cyan("\nPlugin Info\n");
    echo '  Name      : ' . ($title[1] ?? '?') . "\n";
    echo '  Slug      : ' . ($slug[1]  ?? '?') . "\n";
    echo '  Namespace : ' . ($ns[1]    ?? '?') . "\n\n";
}

// ── Make commands ─────────────────────────────────────────────────────────────

function cmd_make_controller(): void
{
    $name = require_make_name('make:controller', 'ExampleController');
    $meta = read_plugin_meta();
    $ns   = $meta['namespace'];

    $dir  = KIT_ROOT . '/backend/app/HTTP/Controllers';
    ensure_dir($dir);

    $path = $dir . '/' . $name . '.php';
    if (file_exists($path)) {
        cli_err("Already exists: backend/app/HTTP/Controllers/{$name}.php");
        exit(1);
    }

    $human = strtolower(preg_replace('/Controller$/', '', $name));
    $tpl = <<<PHP
<?php

namespace {$ns}\\HTTP\\Controllers;

if (!\\defined('ABSPATH')) {
    exit;
}

class {$name}
{
    // This is {$human} controller
}

PHP;

    file_put_contents($path, $tpl);
    cli_ok("Created backend/app/HTTP/Controllers/{$name}.php");
}

