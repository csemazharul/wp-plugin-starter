# ─── Plugin ───────────────────────────────────────────────────────────────────
# Must match the folder name used as the plugin directory.
# After running `php wp-kit plugin:init`, update this to your new slug.
PLUGIN_SLUG=wp-starter-kit

# ─── WordPress ────────────────────────────────────────────────────────────────
WP_PORT=8080
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=password
WP_ADMIN_EMAIL=admin@example.com

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_ROOT_PASSWORD=rootpassword

# ─── Service ports ────────────────────────────────────────────────────────────
ADMINER_PORT=8081
MAILHOG_PORT=8025

# ─── Xdebug ───────────────────────────────────────────────────────────────────
# Options: off | debug | profile | trace
# VS Code / PhpStorm: listen on port 9003
XDEBUG_MODE=off
