  "type": "module",
  "scripts": {
    "all:test": "pnpm ts && pnpm lint",
    "build": "concurrently \"pnpm build:free\" \"pnpm build:pro\"",
    "build:free": "tsc && cross-env VITE_PRO=false vite build",
    "build:pro": "tsc && cross-env VITE_PRO=true vite build",
    "build:silent": "concurrently \"pnpm build:free -l error\" \"pnpm build:pro -l error\"",
    "clean": "rm -rf node_modules",
    "dev:free": "cross-env VITE_PRO=false vite",
    "dev:pro": "cross-env VITE_PRO=true vite",
    "env:clean": "wp-env clean",
    "env:destroy": "wp-env destroy",
    "env:logs": "wp-env logs",
    "env:shell": "wp-env run wordpress bash",
    "preenv:start": "composer install --no-dev",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:wp": "wp-env run wordpress wp",
    "exp:bun-dev": "cross-env VITE_PRO=true bunx --bun vite",
    "lint": "eslint frontend --fix",
    "lint:css": "stylelint frontend/**/*.{css,scss} --aei --color --fix",
    "lint:php": "composer lint",
    "pretty": "npx prettier ./frontend/src --check",
    "pretty:fix": "npx prettier ./frontend/src --check --write",
    "preview": "vite preview",
    "prod": "pnpm prod:free && pnpm prod:pro",
    "prod-zip": "pnpm prod:free-zip && pnpm prod:pro-zip",
    "prod:free": "VITE_PRO=false vite build",
    "prod:pro": "VITE_PRO=true vite build",
    "production": "composer install --no-dev && pnpm install && pnpm i18n && pnpm build",
    "reset": "pnpm clean && pnpm install",
    "test": "vitest --watch=false -c ./vite.config.ts",
    "test:cover": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest --watch=true --ui=false",
    "ts-check": "tsc",
    "type-cov": "pnpx type-coverage -p ./tsconfig.json --strict --details",
    "update-ver": "node scripts/update-version.js"
  },
